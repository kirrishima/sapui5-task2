<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    <Dialog
        id="dialog"
        type="Message"
        title="{i18n>dialogAddRecordTitle}">
        <content>
            <l:VerticalLayout width="100%">
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelId}" labelFor="dialogTextId" />
                    <Input id="dialogInputId" required="true" value="{view>/NewRecord/ID}"
                        valueStateText="{i18n>dialogAddRecordErrorRequired}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelName}" labelFor="dialogTextId1" />
                    <Input id="dialogInputName" required="true" value="{view>/NewRecord/Name}"
                        valueStateText="{i18n>dialogAddRecordErrorRequired}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelAuthor}" labelFor="dialogTextId1" />
                    <Input id="dialogInputAuthor" required="true" value="{view>/NewRecord/Author}"
                        valueStateText="{i18n>dialogAddRecordErrorRequired}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelGenre}" labelFor="dialogTextId1" />
                    <Input id="dialogInputGenre" required="true" value="{view>/NewRecord/Genre}"
                        valueStateText="{i18n>dialogAddRecordErrorRequired}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelReleaseDate}" labelFor="dialogTextId1"
                    />
                    <DatePicker id="dialogDatePicker" value="{view>/NewRecord/ReleaseDate}"
                        valueFormat="yyyy-MM-dd" displayFormat="yyyy-MM-dd"
                        valueStateText="{i18n>dialogAddRecordErrorInvalidDate}" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>dialogAddRecordLabelAvailableQuantity}"
                        labelFor="dialogTextId1" />
                    <Input id="dialogInputAvailableQuantity" required="true"
                        value="{view>/NewRecord/AvailableQuantity}"
                        valueStateText="{i18n>dialogAddRecordErrorInvalidQuantity}" />
                </VBox>
            </l:VerticalLayout>
        </content>
        <beginButton>
            <Button
                type="Emphasized"
                text="{i18n>dialogAddRecordConfirmButton}"
                press=".onConfirmRecordCreation" />
        </beginButton>
        <endButton>
            <Button
                text="{i18n>dialogAddRecordCancelButton}"
                press=".onCancelRecordCreation" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>