<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    <Dialog
        id="odataV2EditProductsDialog"
        type="Message"
        title="{i18n>editODataV2RecordDialogTitle}">
        <content>
            <l:VerticalLayout width="100%">
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelId}"
                        labelFor="odatav2EditIdInput" required="true" />
                    <Input id="odatav2EditIdInput" fieldGroupIds="odatav2EditProductForm" required="true" name="Id"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/ID',
                            type: 'sap.ui.model.odata.type.Int32'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelName}"
                        labelFor="odatav2EditNameInput" required="true" />
                    <Input id="odatav2EditNameInput" fieldGroupIds="odatav2EditProductForm" required="true"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/Name',
                            type: 'sap.ui.model.odata.type.String'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelDescription}"
                        labelFor="odatav2EditDescriptionInput" />
                    <Input id="odatav2EditDescriptionInput" fieldGroupIds="odatav2EditProductForm"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/Description',
                            type: 'sap.ui.model.odata.type.String'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelReleaseDate}"
                        labelFor="odatav2EditReleaseDateInput" required="true" />
                    <DatePicker id="odatav2EditReleaseDateInput" fieldGroupIds="odatav2EditProductForm"
                        required="true"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/ReleaseDate',
                            type: 'sap.ui.model.odata.type.DateTime'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelDiscontinuedDate}"
                        labelFor="odatav2EditDiscontinuedDateInput" />
                    <DatePicker id="odatav2EditDiscontinuedDateInput" fieldGroupIds="odatav2EditProductForm"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/DiscontinuedDate',
                            type: 'sap.ui.model.odata.type.DateTime'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelRating}"
                        labelFor="odatav2EditReleaseRating" required="true" />
                    <Input id="odatav2EditReleaseRating" fieldGroupIds="odatav2EditProductForm"
                        valueStateText="{i18n>createODataV2RecordDialogInputRatingRangeError}"
                        required="true" name="ReleaseRating"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/Rating',
                            type: 'sap.ui.model.odata.type.Int32'
                        }" />
                </VBox>
                <VBox class="sapUiSmallMarginBottom">
                    <Label text="{i18n>createODataV2RecordDialogLabelPrice}"
                        labelFor="odatav2EditPriceInput" required="true" />
                    <Input id="odatav2EditPriceInput" fieldGroupIds="odatav2EditProductForm"
                        valueStateText="{i18n>createODataV2RecordDialogInputPriceRangeError}"
                        required="true" name="Price"
                        value="{
                            path: 'ui>/tabs/odatav2/EditedProduct/Price',
                            type: 'sap.ui.model.odata.type.Decimal'
                        }" />
                </VBox>
            </l:VerticalLayout>
        </content>
        <beginButton>
            <Button id="odatav2EditConfirmButton" type="Emphasized" text="{i18n>createODataV2RecordDialogButtonCreate}"
                press=".onEditProductOdataV2Confirm" />
        </beginButton>
        <endButton>
            <Button id="odatav2EditCancelButton" text="{i18n>createODataV2RecordDialogButtonCancel}"
                press=".onEditProductOdataV2Cancel" />
        </endButton>
    </Dialog>
</core:FragmentDefinition>