{
  "_version": "1.85.0",
  "sap.app": {
    "id": "project1",
    "type": "application",
    "i18n": {
      "bundleName": "project1.i18n.i18n",
      "supportedLocales": [
        ""
      ],
      "fallbackLocale": ""
    },
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.27.0",
      "toolsId": "a5132ce0-649f-4432-b5b3-f87e68bdb4bf"
    },
    "dataSources": {
      "ODataV2Source": {
        "uri": "/V2/OData/OData.svc/",
        "type": "OData",
        "settings": {
          "odataVersion": "2.0",
          "localUri": "localService/ODataV2Service/metadataV2.xml"
        }
      },
      "ODataV4Source": {
        "uri": "/V4/OData/OData.svc/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0",
          "localUri": "localService/ODataV4Service/metadataV4.xml"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": false,
    "dependencies": {
      "minUI5Version": "1.149.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.layout": {},
        "sap.uxap": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "project1.i18n.i18n"
        }
      },
      "v2Model": {
        "dataSource": "ODataV2Source",
        "preload": true,
        "settings": {
          "defaultBindingMode": "TwoWay"
        }
      },
      "v4Model": {
        "dataSource": "ODataV4Source",
        "preload": true,
        "settings": {
          "updateGroupId": "updateGroup"
        }
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        }
      ]
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "controlAggregation": "pages",
        "controlId": "app",
        "transition": "slide",
        "type": "View",
        "viewType": "XML",
        "path": "project1.view",
        "async": true,
        "viewPath": "project1.view"
      },
      "routes": [
        {
          "name": "RouteTab",
          "pattern": "tab/{tabKey}",
          "target": [
            "TargetMain"
          ]
        },
        {
          "name": "RouteProduct",
          "pattern": "Product/{ProductID}",
          "target": "TargetProduct"
        },
        {
          "name": "RouteMain",
          "pattern": ":?query:",
          "target": [
            "TargetMain"
          ]
        }
      ],
      "targets": {
        "TargetMain": {
          "id": "Main",
          "name": "Main"
        },
        "TargetProduct": {
          "id": "Product",
          "name": "Product"
        }
      }
    },
    "rootView": {
      "viewName": "project1.view.App",
      "type": "XML",
      "id": "App",
      "async": true
    }
  }
}